generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model activity_logs {
  id         Int       @id @default(autoincrement())
  admin_id   Int?
  action     String?
  target     String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model announcements {
  id         Int       @id @default(autoincrement())
  title      String    @db.VarChar(255)
  message    String
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model cart {
  id         Int          @id @default(autoincrement())
  user_id    Int?
  session_id String?      @db.VarChar(255)
  product_id Int?
  quantity   Int          @default(1)
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  updated_at DateTime?    @default(now()) @db.Timestamp(6)
  products   products?    @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  cart_items cart_items[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id         Int       @id @default(autoincrement())
  cart_id    Int
  product_id Int
  quantity   Int       @default(1)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  cart       cart      @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([cart_id, product_id])
  @@index([cart_id], map: "idx_cart_items_cart_id")
  @@index([product_id], map: "idx_cart_items_product_id")
}

model categories {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  image_url   String?
}

model email_logs {
  id            Int       @id @default(autoincrement())
  to_email      String
  subject       String?
  status        String?   @default("sent")
  error_message String?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model faqs {
  id          Int       @id @default(autoincrement())
  question    String
  answer      String
  category    String?
  order_index Int?      @default(0)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model newsletter_logs {
  id               Int       @id @default(autoincrement())
  subject          String
  body             String
  sent_by          Int?
  sent_at          DateTime? @default(now()) @db.Timestamptz(6)
  recipients_count Int?
}

model newsletter_subscribers {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(255)
  subscribed_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([email], map: "idx_newsletter_email")
}

model order_items {
  id                  Int       @id @default(autoincrement())
  order_id            Int?
  product_id          Int?
  quantity            Int
  price_at_order_time Decimal?  @db.Decimal(10, 2)
  price               Decimal?  @db.Decimal(10, 2)
  vendor_id           Int?
  orders              orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products            products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors             vendors?  @relation(fields: [vendor_id], references: [id], onUpdate: NoAction)

  @@index([vendor_id], map: "idx_order_items_vendor_id")
}

model orders {
  id           Int           @id @default(autoincrement())
  user_id      Int?
  total_price  Decimal?      @db.Decimal(10, 2)
  status       String?       @default("pending") @db.VarChar(50)
  created_at   DateTime?     @default(now()) @db.Timestamp(6)
  total_amount Decimal?      @db.Decimal(10, 2)
  total        Decimal?      @default(0) @db.Decimal
  vendor_id    Int?
  order_items  order_items[]
  users        users?        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments     payments[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model password_reset_tokens {
  id         Int       @id @default(autoincrement())
  token      String    @unique @db.VarChar(128)
  expires_at BigInt
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user_id    Int
  user_type  String    @db.VarChar(20)

  @@index([expires_at], map: "idx_password_reset_expires")
  @@index([user_id, user_type], map: "idx_password_reset_user")
}

model payments {
  id           Int       @id @default(autoincrement())
  order_id     Int?
  provider     String?   @db.VarChar(50)
  provider_ref String?   @db.VarChar(120)
  amount       Decimal   @db.Decimal(12, 2)
  currency     String?   @default("KES") @db.VarChar(10)
  status       String?   @default("pending") @db.VarChar(30)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  orders       orders?   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model product_variants {
  id         Int       @id @default(autoincrement())
  product_id Int?
  sku        String?   @unique @db.VarChar(100)
  price      Decimal   @db.Decimal(10, 2)
  stock      Int?      @default(0)
  attributes Json?
  image_url  String?   @db.VarChar(500)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model products {
  id                      Int                     @id @default(autoincrement())
  name                    String                  @db.VarChar(100)
  description             String?
  price                   Decimal                 @db.Decimal(10, 2)
  image_url               String?
  created_at              DateTime?               @default(now()) @db.Timestamp(6)
  stock                   Int?                    @default(0)
  vendor_id               Int?
  category                String?
  sku                     String?                 @unique @db.VarChar(100)
  weight                  Decimal?                @db.Decimal(10, 2)
  dimensions              String?                 @db.VarChar(100)
  shipping_cost           Decimal?                @default(0) @db.Decimal(10, 2)
  free_shipping_threshold Decimal?                @db.Decimal(10, 2)
  product_type            String?                 @default("simple") @db.VarChar(50)
  attributes              Json?
  gallery_images          String[]
  updated_at              DateTime?               @default(now()) @db.Timestamp(6)
  status                  String?                 @default("draft") @db.VarChar(20)
  created_by              String?                 @default("vendor") @db.VarChar(20)
  approved_by             Int?
  approved_at             DateTime?               @db.Timestamp(6)
  rejection_reason        String?
  submitted_at            DateTime?               @db.Timestamp(6)
  original_price          Decimal?                @db.Decimal(10, 2)
  features                Json?
  warranty_info           String?
  shipping_info           String?
  return_policy           String?
  specifications          Json?
  tags                    Json?
  brand                   String?                 @db.VarChar(100)
  color                   String?                 @db.VarChar(50)
  material                String?                 @db.VarChar(100)
  estimated_delivery_days Int?                    @default(3)
  is_featured             Boolean?                @default(false)
  is_bestseller           Boolean?                @default(false)
  rating                  Decimal?                @default(0.00) @db.Decimal(3, 2)
  review_count            Int?                    @default(0)
  meta_title              String?                 @db.VarChar(255)
  meta_description        String?
  cart                    cart[]
  cart_items              cart_items[]
  order_items             order_items[]
  product_variants        product_variants[]
  vendors                 vendors?                @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviews                 reviews[]
  vendor_shipping_zones   vendor_shipping_zones[]

  @@index([brand], map: "idx_products_brand")
  @@index([category], map: "idx_products_category")
  @@index([price], map: "idx_products_price")
  @@index([vendor_id], map: "idx_products_vendor")
}

model reported_issues {
  id             Int       @id @default(autoincrement())
  reporter_name  String?
  reporter_email String?
  description    String
  url            String?
  priority       String?   @default("normal")
  status         String    @default("open")
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)

  @@index([status], map: "idx_reported_issues_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id         Int       @id @default(autoincrement())
  product_id Int?
  user_id    Int?
  rating     Int?
  comment    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model support_messages {
  id         Int       @id @default(autoincrement())
  name       String?
  email      String
  subject    String?
  message    String
  status     String    @default("open")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([email], map: "idx_support_messages_email")
  @@index([status], map: "idx_support_messages_status")
}

model user_sessions {
  id            Int       @id @default(autoincrement())
  user_id       Int
  session_token String    @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  expires_at    DateTime  @db.Timestamp(6)
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(100)
  email          String           @unique @db.VarChar(100)
  password       String           @db.VarChar(255)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  is_admin       Boolean?         @default(false)
  refresh_token  String?
  last_ip        String?          @db.VarChar(45)
  last_activity  DateTime?        @db.Timestamp(6)
  session_valid  Boolean?         @default(true)
  cart           cart[]
  orders         orders[]
  reviews        reviews[]
  user_sessions  user_sessions[]
  vendor_members vendor_members[]
}

model vendor_categories {
  id            Int       @id @default(autoincrement())
  vendor_id     Int?
  category_name String    @db.VarChar(100)
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  vendors       vendors?  @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model vendor_members {
  id        Int     @id @default(autoincrement())
  vendor_id Int
  user_id   Int
  role      String  @db.VarChar(30)
  users     users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors   vendors @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vendor_id, user_id])
}

model vendor_payout_accounts {
  id          Int       @id @default(autoincrement())
  vendor_id   Int?
  provider    String?   @db.VarChar(50)
  account_ref String?   @db.VarChar(150)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  vendors     vendors?  @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vendor_id, provider])
}

model vendor_product_defaults {
  id                              Int       @id @default(autoincrement())
  vendor_id                       Int?      @unique
  default_shipping_cost           Decimal?  @db.Decimal(10, 2)
  default_free_shipping_threshold Decimal?  @db.Decimal(10, 2)
  default_category                String?   @db.VarChar(100)
  auto_submit_for_approval        Boolean?  @default(false)
  created_at                      DateTime? @default(now()) @db.Timestamp(6)
  vendors                         vendors?  @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model vendor_sessions {
  id            Int       @id @default(autoincrement())
  vendor_id     Int
  session_token String    @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  expires_at    DateTime  @db.Timestamp(6)
  vendors       vendors   @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_vendor_sessions_expires")
  @@index([session_token], map: "idx_vendor_sessions_token")
  @@index([vendor_id], map: "idx_vendor_sessions_vendor")
}

model vendor_shipping_zones {
  id             Int       @id @default(autoincrement())
  vendor_id      Int?
  product_id     Int?
  country        String?   @db.VarChar(100)
  region         String?   @db.VarChar(100)
  cost           Decimal?  @default(0) @db.Decimal(10, 2)
  free_threshold Decimal?  @db.Decimal(10, 2)
  estimated_days Int?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  products       products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors        vendors?  @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model vendors {
  id                      Int                      @id @default(autoincrement())
  legal_name              String?                  @db.VarChar(200)
  email                   String                   @unique @db.VarChar(150)
  phone                   String?                  @db.VarChar(50)
  address                 String?
  created_at              DateTime?                @default(now()) @db.Timestamp(6)
  company_name            String?                  @db.VarChar(255)
  contact_person          String?                  @db.VarChar(255)
  password                String?                  @db.VarChar(255)
  status                  vendor_status?           @default(pending)
  country                 String?                  @db.VarChar(100)
  business_type           String?                  @db.VarChar(50)
  county                  String?                  @db.VarChar(100)
  is_verified             Boolean?                 @default(false)
  verification_token      String?
  verification_expires    DateTime?                @db.Timestamp(6)
  shipping_rate           Decimal?                 @default(0) @db.Decimal
  shipping_policy         String?
  return_policy           String?
  company_logo            String?                  @db.VarChar(500)
  updated_at              DateTime?                @default(now()) @db.Timestamp(6)
  plan_type               String?                  @default("basic") @db.VarChar(50)
  max_products            Int?                     @default(10)
  current_approved_count  Int?                     @default(0)
  is_trusted_vendor       Boolean?                 @default(false)
  order_items             order_items[]
  products                products[]
  vendor_categories       vendor_categories[]
  vendor_members          vendor_members[]
  vendor_payout_accounts  vendor_payout_accounts[]
  vendor_product_defaults vendor_product_defaults?
  vendor_sessions         vendor_sessions[]
  vendor_shipping_zones   vendor_shipping_zones[]
}

enum vendor_status {
  pending
  approved
  rejected
}
// Add these models to your existing schema.prisma

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Update your existing User model to work with NextAuth
